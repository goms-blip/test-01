# local-only assets and tooling — not needed at runtime on Vercel
.env.local
.env.local.*
.DS_Store

# legacy HTML versions kept locally for comparison
_legacy/

# dev-only Node http server (replaced by /api/**.mjs on Vercel)
admin/server.mjs

# bulky local image folders — production images live in Supabase Storage
images/
images_gpt/
images_gpt2/

# one-off scripts for seeding / image upload / extraction
scripts/

# source data + migrations are dev artifacts, not runtime
data/
supabase/

# dev logs
work_log.md
*.log
