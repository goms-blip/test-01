# ============================================================
# Auth 기반 커뮤니티 앱 — 환경 변수 샘플
# ------------------------------------------------------------
# 이 파일을 복사해 ".env" 로 저장한 뒤 실제 값을 채우세요.
#   $ cp .env.example .env
#
# Supabase 대시보드 > Project Settings > API 에서 확인 가능합니다.
# ANON KEY 는 클라이언트에서 사용해도 안전한 공개 키입니다.
# (RLS 정책으로 권한이 통제되므로 노출돼도 OK)
# 단, SERVICE_ROLE 키는 절대 클라이언트에 노출하지 마세요.
# ============================================================

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# 개발 서버 포트 (기본 4000)
PORT=4000
