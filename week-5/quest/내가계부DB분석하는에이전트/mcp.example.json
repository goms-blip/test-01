{
  "_comment": [
    "Claude Code / Cursor / Claude Desktop 에서 Supabase MCP 서버 등록 예제.",
    "환경별 위치:",
    "  - Claude Code   : ~/.claude/mcp_servers.json  (또는 프로젝트 .mcp.json)",
    "  - Claude Desktop: ~/Library/Application Support/Claude/claude_desktop_config.json",
    "  - Cursor        : ~/.cursor/mcp.json",
    "키와 password 는 절대 git 에 커밋하지 마세요."
  ],
  "mcpServers": {
    "supabase-ledger": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase",
        "--read-only"
      ],
      "env": {
        "SUPABASE_URL": "https://YOUR-PROJECT-REF.supabase.co",
        "SUPABASE_ANON_KEY": "YOUR_ANON_KEY_HERE"
      }
    },
    "_alternative_postgres": {
      "_comment": "Supabase 전용 MCP 가 막힐 때 일반 Postgres MCP 로도 동일하게 가능",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "POSTGRES_CONNECTION_STRING": "postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres?sslmode=require"
      }
    }
  }
}
