# ============================================================
# 가계부 앱 환경변수 샘플
# ------------------------------------------------------------
# 이 파일을 복사해 ".env" 로 저장한 뒤 실제 값으로 채우세요.
#   $ cp .env.example .env
#
# DATABASE_URL 은 Supabase 프로젝트의 [Connection Pooling]
# 항목에서 6543 포트(transaction mode) 문자열을 권장합니다.
# 절대 이 파일이나 .env 를 git 에 커밋하지 마세요.
# ============================================================

# 예시: postgres://postgres.<ref>:<PASSWORD>@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
DATABASE_URL=

# 서버 포트 (기본 3000)
PORT=3000

# /api/* 보호용 Bearer 토큰 (선택)
# 설정하면 모든 /api/* 요청은 "Authorization: Bearer <API_TOKEN>" 헤더를 요구
# 클라이언트는 페이지 첫 진입 시 prompt 로 받아 localStorage(`ledger.api.token`)에 저장
# 비워두면 dev 모드 — 인증 우회 (단일 사용자 로컬 개발)
# 강력한 무작위 값 생성:  openssl rand -hex 32
API_TOKEN=
